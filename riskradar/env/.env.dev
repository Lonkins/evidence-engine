# This file includes environment variables that will be committed to git by default.

# Built-in environment variables
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=dev

# Generated during provision, you can also add your own variables.
TEAMS_APP_ID=

# MCP server URL — override with your deployed URL before provisioning
# For local demo: use ngrok (ngrok http 3000) and paste the https:// URL here
# For production: deploy server/ to Railway or Render and paste the URL here
MCP_SERVER_URL=https://rocklike-unfrozen-clash.ngrok-free.dev/api


# Environment variables for Agent Evaluations
AZURE_AI_OPENAI_ENDPOINT=
AZURE_AI_API_KEY=
AZURE_AI_API_VERSION=
AZURE_AI_MODEL_NAME=