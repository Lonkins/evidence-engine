# Live Interrogation backend — copy to .env (gitignored). Never commit .env.
# The browser NEVER sees these values; they live only in this process.

# Azure AI Search (Foundry IQ) — admin key required: the turn loop writes
# testimony documents into the 'evidence' index and deletes them on reset.
AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=
AZURE_KNOWLEDGE_BASE_NAME=evidence-kb
AZURE_KNOWLEDGE_SOURCE_NAME=evidence-ks
AZURE_SEARCH_INDEX_NAME=evidence

# GitHub Models free tier. Any GitHub token works, e.g.:
#   GITHUB_MODELS_TOKEN=$(gh auth token) npm start
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# WP3-calibrated fail-closed reranker threshold (see HANDOFF.md)
NO_EVIDENCE_THRESHOLD=3.5

PORT=8787
# Comma-separated origins allowed to call this API (Vite dev server by default)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
