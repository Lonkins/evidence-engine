# Live Interrogation backend — copy to .env (gitignored). Never commit .env.
# The browser NEVER sees these values; they live only in this process.

# Azure AI Search (Foundry IQ) — admin key required: the turn loop writes
# testimony documents into the 'evidence' index and deletes them on reset.
AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=
AZURE_KNOWLEDGE_BASE_NAME=evidence-kb
AZURE_KNOWLEDGE_SOURCE_NAME=evidence-ks
AZURE_SEARCH_INDEX_NAME=evidence

# GitHub Models free tier (plays the witnesses). Any GitHub token works, e.g.:
#   GITHUB_MODELS_TOKEN=$(gh auth token) npm start
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Foundry IQ as the verdict brain. With both set, a challenge verdict is produced
# by the knowledge base's own answer synthesis (gpt-4.1-mini bound to evidence-kb
# via spike/08-answer-synthesis.sh), and the deterministic check becomes a
# disclosed cross-check. Leave them unset (or minimal) to use the deterministic
# check as the verdict — the no-Azure-model fallback.
IQ_VERDICT_ENABLED=true
KB_REASONING_EFFORT=medium

# Fail-closed reranker thresholds, calibrated live (question 3.5 / declarative
# claim 2.0 / testimony 1.0; bring-your-own 1.0). Defaults below; override if needed.
NO_EVIDENCE_THRESHOLD=3.5
CLAIM_EVIDENCE_THRESHOLD=2.0
TESTIMONY_THRESHOLD=1.0
BYO_VERDICT_THRESHOLD=1.0

# Minutes of inactivity after which an abandoned bring-your-own source partition
# is purged from the shared index.
BYO_TTL_MINUTES=30

PORT=8787
# Comma-separated origins allowed to call this API (Vite dev server by default)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
