# RiskRadar MCP Server — environment variables
#
# Copy this file to .env for local development.
# When OAUTH_TENANT_ID or OAUTH_AUDIENCE are not set, Bearer token
# validation is automatically skipped (safe for localhost).

# ── OAuth 2.0 / Azure Active Directory ───────────────────────────────────────
#
# Required for production token validation. Obtain from Azure portal:
#   1. Create an App Registration in Azure AD for the MCP server
#   2. Under Overview, copy the Directory (tenant) ID → OAUTH_TENANT_ID
#   3. Copy the Application (client) ID → OAUTH_AUDIENCE
#
# Tokens are validated against:
#   Issuer:   https://login.microsoftonline.com/<OAUTH_TENANT_ID>/v2.0
#   Audience: <OAUTH_AUDIENCE>
#   JWKS:     https://login.microsoftonline.com/<OAUTH_TENANT_ID>/discovery/v2.0/keys

OAUTH_TENANT_ID=<your-azure-ad-tenant-id>
OAUTH_AUDIENCE=<your-app-registration-client-id>

# ── SharePoint — Approved Tools Registry (production store) ──────────────────
#
# When ALL four SP_* vars are set the MCP server switches from its local
# JSON file store to the real SharePoint list via Microsoft Graph.
#
# Prerequisites:
#   1. Run riskradar/sharepoint/provision-registry.ps1 to create the list
#   2. Create an Azure App Registration with Sites.ReadWrite.All (application)
#   3. Grant admin consent in the Azure portal
#   4. Update server/src/store.ts to import from graph-store.ts
#      (see riskradar/sharepoint/README.md for the one-line change)
#
# SP_TENANT_ID    Directory (tenant) ID from Azure AD Overview
# SP_CLIENT_ID    Application (client) ID of the App Registration
# SP_CLIENT_SECRET Client secret value (not the secret ID)
# SP_SITE_URL     Full URL of the SharePoint site, e.g.
#                 https://contoso.sharepoint.com/sites/IT
# SP_LIST_NAME    Display name of the list (default: "Approved Tools Registry")

SP_TENANT_ID=<your-azure-ad-tenant-id>
SP_CLIENT_ID=<app-registration-client-id-for-sharepoint>
SP_CLIENT_SECRET=<client-secret-value>
SP_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
SP_LIST_NAME=Approved Tools Registry

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000
