# Evidence Engine MCP Server — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# -------------------------------------------------------------------
# Foundry IQ (Azure AI Search) — required for full game experience
# Without these, the server falls back to local corpus keyword search
# -------------------------------------------------------------------

# Azure AI Search service endpoint
# Format: https://<your-service-name>.search.windows.net
AZURE_SEARCH_ENDPOINT=

# Azure AI Search admin or query key
# Portal: your search service > Keys > Primary admin key
AZURE_SEARCH_KEY=

# Name of the knowledge base (created in spike stage 3)
AZURE_KNOWLEDGE_BASE_NAME=evidence-kb

# Name of the knowledge source bound to the KB (spike stage 3)
AZURE_KNOWLEDGE_SOURCE_NAME=evidence-ks

# Name of the search index (created in spike stage 2)
AZURE_SEARCH_INDEX_NAME=evidence

# -------------------------------------------------------------------
# Foundry IQ as the verdict brain (A6) — answer synthesis
# When enabled, check_claim's verdict is produced by the KB's own grounded
# reasoning (the identical path the live-server uses), not just the local
# heuristic. Requires the KB provisioned with a bound model + answerSynthesis
# (spike/08-answer-synthesis.sh). Effort must be low/medium (minimal is LLM-free
# and cannot synthesise a verdict).
# -------------------------------------------------------------------
IQ_VERDICT_ENABLED=false
KB_REASONING_EFFORT=minimal

# Fail-closed threshold for no-evidence detection
# WP3 Calibration (2026-06-11): in-corpus baseline ~3.99, out-of-corpus 0.0
# Recommended threshold: 3.5 (88% of baseline) — conservative cutoff
# Rule: If max(rerankerScore) < this threshold, return no references (fail-closed)
NO_EVIDENCE_THRESHOLD=3.5

# -------------------------------------------------------------------
# Setup guide
# -------------------------------------------------------------------
#
# 1. Run the spike scripts in evidence-engine/spike/ to provision
#    Azure AI Search and create the knowledge base.
#    See spike/README.md for instructions.
#
# 2. Upload the corpus documents from evidence-engine/corpus/ to the
#    knowledge base using spike/02-create-index.sh (with your case docs).
#
# 3. Fill in AZURE_SEARCH_ENDPOINT and AZURE_SEARCH_KEY above.
#
# 4. Start the MCP server: npm run dev (or npm run build && npm start)
#
# Dev mode (no Azure): leave these blank. The server will use the local
# corpus directory for keyword search. Grounding works but citations
# are file-based rather than coming from Foundry IQ.
