{
  "inputs": [
    {
      "id": "azureSearchEndpoint",
      "type": "promptString",
      "description": "Azure AI Search service endpoint — e.g. https://evidence-engine-search.search.windows.net",
      "password": false
    },
    {
      "id": "azureSearchKey",
      "type": "promptString",
      "description": "Azure AI Search admin key (Portal: your search service → Keys → Primary admin key)",
      "password": true
    }
  ],
  "servers": {
    "evidence-engine": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/server/dist/index.js"],
      "env": {
        "AZURE_SEARCH_ENDPOINT": "${input:azureSearchEndpoint}",
        "AZURE_SEARCH_KEY": "${input:azureSearchKey}",
        "AZURE_KNOWLEDGE_BASE_NAME": "evidence-kb",
        "AZURE_SEARCH_INDEX_NAME": "evidence"
      }
    },
    "evidence-engine-foundry-iq": {
      "url": "https://evidence-engine-search.search.windows.net/knowledgebases/evidence-kb/mcp?api-version=2026-05-01-preview",
      "type": "http",
      "headers": {
        "api-key": "${input:azureSearchKey}"
      }
    }
  }
}
